# Supabase — obtén estos valores en supabase.com > tu proyecto > Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# PayPal — Client ID público (seguro en frontend)
VITE_PAYPAL_CLIENT_ID=tu_paypal_client_id

# URL pública de la app
VITE_APP_URL=https://psiconecta.app

# ─── NUNCA agregar estas claves con prefijo VITE_ ────────────────────────────
# Las siguientes claves son SECRETAS y deben estar ÚNICAMENTE en Supabase Secrets
# (supabase.com > tu proyecto > Settings > Edge Functions > Secrets):
#
#   DAILY_API_KEY        → Edge Function create-daily-room
#   ANTHROPIC_API_KEY    → Edge Function ai-checkin
#   PAYPAL_CLIENT_SECRET → Edge Functions de pago
#   RESEND_API_KEY       → Edge Functions de email
